# Copy to .env and fill in. Required only to RUN the generation engine.
# Get a key at https://console.anthropic.com/  (never commit the real .env)
ANTHROPIC_API_KEY=sk-ant-...

# OPTIONAL — premium human voice for the live Voice-agent call (Agent Studio →
# Shady Blinds - Voice → Preview Workflow → Start Call). Without any voice key the
# call falls back to the browser's (robotic) built-in voice. Two providers are
# supported; set at least one key.
#
# Which provider: if unset, auto-picks Deepgram when DEEPGRAM_API_KEY is present,
# else ElevenLabs. Force one explicitly with TTS_PROVIDER=deepgram | elevenlabs.
TTS_PROVIDER=

# Deepgram Aura — get a key at https://console.deepgram.com/ (free credit).
DEEPGRAM_API_KEY=
# Optional: any Aura voice (defaults to aura-2-thalia-en). e.g. aura-2-andromeda-en,
# aura-2-helena-en, aura-2-apollo-en. See https://developers.deepgram.com/docs/tts-models
DEEPGRAM_MODEL=

# ElevenLabs — get a key at https://elevenlabs.io/ → Profile → API Keys.
ELEVENLABS_API_KEY=
# Optional: any voice from your ElevenLabs dashboard (defaults to "Sarah").
ELEVENLABS_VOICE_ID=
# Optional: model. Default eleven_multilingual_v2 (best/most human); use
# eleven_turbo_v2_5 or eleven_flash_v2_5 for lower latency.
ELEVENLABS_MODEL_ID=

# OPTIONAL — PRODUCTION HOSTING (server.ts). Not needed for local `npm run dev`.
# PORT the production server listens on (Render sets this automatically).
PORT=
# "Sign in with Google" gate — set BOTH client id + secret to require login.
# Create an OAuth client at https://console.cloud.google.com (Web application),
# with Authorized redirect URI = <BASE_URL>/auth/callback . Leave blank = no gate.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Who may sign in (defaults to invoca.com if unset).
ALLOWED_EMAIL_DOMAIN=invoca.com
# Random string that signs the login cookie — generate with `openssl rand -hex 32`.
SESSION_SECRET=
# Public URL of the deployment, e.g. https://invoca-demo.onrender.com (used to
# build the OAuth redirect). If unset, it's derived from the incoming request.
BASE_URL=

# OPTIONAL — Gumloop agent that builds the 3 HTML leave-behinds (Voice Screenpop,
# SMS Screenpop, Voice Routing Demo) from just the customer URL, in parallel with
# the platform demo. Without these the artifacts stay unseeded (My Reports simply
# won't show the rows). Get your API key at Gumloop → Settings → API / Credentials.
GUMLOOP_API_KEY=
# Your Gumloop workspace/user id (shown in the "Run via API" panel of a flow).
GUMLOOP_USER_ID=
# Pipeline (saved-item) IDs — one per artifact. If a single pipeline outputs all
# three, put the same id in all three (the code de-dupes the run).
GUMLOOP_PIPELINE_VOICE_SCREENPOP=
GUMLOOP_PIPELINE_SMS_SCREENPOP=
GUMLOOP_PIPELINE_VOICE_ROUTING_DEMO=
